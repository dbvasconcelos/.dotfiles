# Colors
set notification-error-bg       "#32302f"
set notification-error-fg       "#ea6962"
set notification-warning-bg     "#32302f"
set notification-warning-fg     "#d8a657"
set notification-bg             "#32302f"
set notification-fg             "#a9b665"

set completion-bg               "#3c3836"
set completion-fg               "#d4be98"
set completion-group-bg         "#3c3836"
set completion-group-fg         "#928374"
set completion-highlight-bg     "#7daea3"
set completion-highlight-fg     "#3c3836"

set index-bg                    "#3c3836"
set index-fg                    "#d4be98"
set index-active-bg             "#7daea3"
set index-active-fg             "#3c3836"

set inputbar-bg                 "#3c3836"
set inputbar-fg                 "#d4be98"

set statusbar-bg                "#3c3836"
set statusbar-fg                "#d4be98"

set highlight-color             "#d8a657"
set highlight-active-color      "#e78a4e"

set default-bg                  "#282828"
set default-fg                  "#d4be98"
set render-loading-bg           "#282828"
set render-loading-fg           "#d4be98"

set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set selection-clipboard clipboard
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
map p print
map g goto top
