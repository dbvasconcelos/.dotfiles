# Shell aliases definition

aur=paru

# Use neovim for vim.
[ -x "$(command -v nvim)" ] && alias vim="nvim" vimdiff="nvim -d"

# Use eza for ls.
[ -x "$(command -v eza)" ] && alias ls="eza --icons --color=always --group-directories-first"

# use aur for pacman.
[ -x "$(command -v paru)" ] && alias pacman="$aur"

# use bat for cat.
[ -x "$(command -v bat)" ] && alias cat="bat"

# Trash instead of rm.
[ -x "$(command -v trash)" ] && alias rm="trash"

# Verbosity on mkdir.
alias mkdir="mkdir -pv"

# Verbosity on mv/cp.
alias cp="cp -iv"
alias mv="mv -iv"

# Colorization.
alias diff="diff --color=auto"

# remove orphaned packages.
alias autoremove='if [ -z "$($aur -Qtdq)" ]; then echo "no orphan packages"; else $aur -Rns $($aur -Qtdq); fi'

# get error messages from journalctl.
alias jctl="journalctl -p 4 -xb"
